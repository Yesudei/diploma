# ==========================================
# AI-Based Music Production System
# Environment Configuration
# ==========================================

# FastAPI Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://music_user:secure_password@localhost:5432/music_production_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=music-production-uploads
AWS_S3_MAX_FILE_SIZE=52428800  # 50MB in bytes

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_APP_NAME=AI Music Production System
NEXT_PUBLIC_APP_VERSION=1.0.0

# AI/ML Configuration
MODEL_CNN_PATH=./ml_models/cnn_mixer_model.h5
MODEL_MUSICVAE_PATH=./ml_models/music_vae_model
MODEL_RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DB_PATH=./data/chroma_db
OLLAMA_API_URL=http://localhost:11434
OPENAI_API_KEY=your-openai-api-key

# Audio Processing
LIBROSA_SR=44100  # Sample rate
LIBROSA_N_FFT=2048
LIBROSA_HOP_LENGTH=512
SPECTROGRAM_IMAGE_SIZE=224  # For CNN model

# Caching
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_AUDIO_FORMATS=.wav,.mp3,.flac,.ogg
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@musicproduction.com

# Feature Flags
ENABLE_MELODY_GENERATION=true
ENABLE_CHATBOT=true
ENABLE_MARKETPLACE=true
ENABLE_ANALYTICS=false

# Development
DEBUG=false
TESTING=false
